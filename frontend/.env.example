# Copy to .env.local for dev, or set on server for prod build

# 1inch: browser uses same-origin /oneinch proxy (backend-signals). Set ONEINCH_API_KEY on that service
# (repo root .env.example / ops env) — do not put the 1inch token in Vite (it would ship in the bundle).

# WalletConnect Cloud project ID — required for QR/mobile wallets
# Get one free at https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=your_project_id_here

# App URL (optional, for WalletConnect metadata)
VITE_APP_URL=https://dex.kobbex.com

# API base (optional; prod defaults to /api/v1 relative)
# VITE_API_URL=/api/v1

# Optional wallet session API (POST /wallet/connect, /wallet/disconnect, /wallet/switch-chain).
# Omit or leave false when the backend does not expose these routes (recommended for dex.kobbex.com):
# chain switching uses the wallet provider only; no 404s from a dead switch-chain route.
# VITE_ENABLE_WALLET_SESSION_API=true

# Phase 1 — 1inch integrator fee only (optional). Invalid config is ignored; swaps still work.
# VITE_FEE_ENABLED=true
# VITE_FEE_BPS=30
# VITE_FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# Uniswap V3 fee wrapper (Ethereum mainnet, ERC20→ERC20 only). When unset or disabled, swaps use the direct SwapRouter02 path.
# Defaults: wrapper OFF unless VITE_UNISWAP_WRAPPER_ENABLED is explicitly truthy (1/true/yes/on).
# VITE_UNISWAP_WRAPPER_ENABLED=true
# Patched production wrapper (do not use deprecated 0x171ea5446F26967cba4d1E21865fc766f4ea26dF)
# VITE_UNISWAP_WRAPPER_ADDRESS=0xe07f5940487a58E30F9fa711Be358FB036B0Fc44
# Optional: protocol fee in bps for UI copy only (must match deployed FEE_BPS; default 20 = 0.20%)
# VITE_UNISWAP_WRAPPER_FEE_BPS=20

# PancakeSwap V3 fee wrapper (BNB Chain / chain 56, ERC20→ERC20 only). When unset or disabled, swaps use the direct SmartRouter path.
# VITE_PANCAKE_WRAPPER_ENABLED=true
# VITE_PANCAKE_WRAPPER_ADDRESS=0x88a30C39475CfD1f6660c2D21FC8379A2A369DE3
# Optional: protocol fee in bps for UI copy (match deployed FEE_BPS; default 50 = 0.50%)
# VITE_PANCAKE_WRAPPER_FEE_BPS=50
