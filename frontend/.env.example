# Copy to .env.local for dev, or set on server for prod build

# WalletConnect Cloud project ID — required for QR/mobile wallets
# Get one free at https://cloud.walletconnect.com
VITE_WC_PROJECT_ID=your_project_id_here

# App URL (optional, for WalletConnect metadata)
VITE_APP_URL=https://dex.kobbex.com

# API base (optional; prod defaults to /api/v1 relative)
# VITE_API_URL=/api/v1

# Optional wallet session API (POST /wallet/connect, /wallet/disconnect). Omit or leave false
# when the backend does not expose these routes (WalletConnect + read-only only).
# VITE_ENABLE_WALLET_SESSION_API=true

# Phase 1 — 1inch integrator fee only (optional). Invalid config is ignored; swaps still work.
# VITE_FEE_ENABLED=true
# VITE_FEE_BPS=30
# VITE_FEE_RECIPIENT=0x0000000000000000000000000000000000000000
